{
  "name": "@wiggwigg/crypto",
  "version": "0.1.0",
  "description": "Cryptographic core of WIGGWIGG: key derivation, encryption, sealing, and signing primitives.",
  "keywords": [
    "cryptography",
    "argon2id",
    "x25519",
    "ed25519",
    "aes-gcm",
    "bip39",
    "hkdf",
    "zero-knowledge"
  ],
  "license": "MIT",
  "author": "WIGGWIGG",
  "homepage": "https://github.com/WiggWiggDev/crypto",
  "repository": {
    "type": "git",
    "url": "https://github.com/WiggWiggDev/crypto.git"
  },
  "bugs": {
    "url": "https://github.com/WiggWiggDev/crypto/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./asymmetric": {
      "types": "./dist/asymmetric/index.d.ts",
      "default": "./dist/asymmetric/index.js"
    },
    "./auth-signing": {
      "types": "./dist/auth-signing/index.d.ts",
      "default": "./dist/auth-signing/index.js"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "default": "./dist/encryption/index.js"
    },
    "./kdf": {
      "types": "./dist/kdf/index.d.ts",
      "default": "./dist/kdf/index.js"
    },
    "./params": {
      "types": "./dist/params.d.ts",
      "default": "./dist/params.js"
    },
    "./pin-unlock": {
      "types": "./dist/pin-unlock/index.d.ts",
      "default": "./dist/pin-unlock/index.js"
    },
    "./recovery": {
      "types": "./dist/recovery/index.d.ts",
      "default": "./dist/recovery/index.js"
    },
    "./versions": {
      "types": "./dist/versions.d.ts",
      "default": "./dist/versions.js"
    },
    "./auth-proof": {
      "types": "./dist/auth-proof/index.d.ts",
      "default": "./dist/auth-proof/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "all": "npm run type-check && npm run test && npm run build"
  },
  "dependencies": {
    "@noble/ciphers": "2.1.1",
    "@noble/curves": "2.2.0",
    "@noble/hashes": "2.0.1",
    "@scure/bip39": "2.0.0"
  },
  "devDependencies": {
    "@types/node": "24.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "publishConfig": {
    "access": "public"
  }
}
